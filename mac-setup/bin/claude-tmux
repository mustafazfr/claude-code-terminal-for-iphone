#!/usr/bin/env bash
#
# claude-tmux [session] [account]
#
# Adı verilen tmux oturumuna bağlanır, yoksa oluşturur. Claude'u OTOMATİK
# BAŞLATMAZ — seni home dizininde normal bir kabuğa bırakır. Kontrol sende.
#
# account verilirse o Claude hesabının OAuth token'ı bu oturuma yüklenir
# (çoklu hesap; bkz. claude-account). Verilmezse varsayılan env kullanılır.
#
set -euo pipefail

SESSION="${1:-main}"
ACCOUNT="${2:-}"

# SSH (login olmayan) kabuklarda da tmux/claude/node PATH'te olsun:
export PATH="/opt/homebrew/bin:$HOME/.local/bin:$PATH"

# Claude girişi (Keychain SSH'tan okunamaz → OAuth token). Önce seçilen hesap,
# yoksa eski tek-hesap env dosyası. Token'ı oturumun kendi ortamına gömeriz.
TOK=""
if [ -n "$ACCOUNT" ] && command -v claude-account >/dev/null 2>&1; then
  TOK="$(claude-account token "$ACCOUNT" 2>/dev/null || true)"
fi
if [ -z "$TOK" ] && [ -f "$HOME/.config/claude-remote/env" ]; then
  . "$HOME/.config/claude-remote/env"
  TOK="${CLAUDE_CODE_OAUTH_TOKEN:-}"
fi
TOK="$(printf %s "$TOK" | tr -d '[:space:]')"   # kopyalama boşluklarını temizle (401 önleme)

# -A: oturum varsa ona bağlan, yoksa oluştur. caffeinate Mac'i uyutmaz.
# Token'ı tmux oturumunun ortamına koy (o oturumdaki tüm claude çağrıları kullanır).
exec env CLAUDE_CODE_OAUTH_TOKEN="$TOK" \
  tmux new-session -A -s "$SESSION" "caffeinate -dis ${SHELL:-/bin/zsh} -l"
